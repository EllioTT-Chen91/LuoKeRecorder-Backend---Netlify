POST http://localhost:3001/api/sync
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6NiwidXNlcm5hbWUiOiJ0ZXN0dXNlciIsImlhdCI6MTc3Nzc3NTY1NywiZXhwIjoxNzc4MzgwNDU3fQ.0iWIoSh9xBolhZB903EpYD9K-ftbgKmaQS2w0LBBtGM

{
  "recordId": "test001",
  "target": "测试闪光精灵",
  "captures": [1,2,3],
  "quickButtons": [1,2]
}

